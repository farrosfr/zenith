  <script>
    function setupTabs() {
      const tabs = document.querySelectorAll('[data-tab]');
      const panels = document.querySelectorAll('[data-tab-panel]');

      if (!tabs.length) return;

      tabs.forEach(tab => {
        const newTab = tab.cloneNode(true);
        tab.parentNode?.replaceChild(newTab, tab);

        newTab.addEventListener('click', () => {
          const targetId = newTab.getAttribute('data-tab');
          if (!targetId) return;

          // Deactivate all tabs and panels
          tabs.forEach(t => {
            t.classList.remove('bg-primary-50', 'dark:bg-primary-900/20', 'text-primary-700', 'dark:text-primary-300', 'border-primary-200', 'dark:border-primary-800', 'shadow-sm');
            t.classList.add('text-slate-600', 'dark:text-slate-400', 'border-transparent');
            t.setAttribute('aria-selected', 'false');
            const iconWrapper = t.querySelector('.w-10.h-10');
            if (iconWrapper) {
              iconWrapper.classList.remove('bg-primary-100', 'dark:bg-primary-900/40', 'text-primary-600', 'dark:text-primary-400');
              iconWrapper.classList.add('bg-slate-100', 'dark:bg-slate-800', 'text-slate-500', 'dark:text-slate-400');
            }
          });

          panels.forEach(p => p.classList.add('hidden'));

          // Activate target
          newTab.classList.remove('text-slate-600', 'dark:text-slate-400', 'border-transparent');
          newTab.classList.add('bg-primary-50', 'dark:bg-primary-900/20', 'text-primary-700', 'dark:text-primary-300', 'border-primary-200', 'dark:border-primary-800', 'shadow-sm');
          newTab.setAttribute('aria-selected', 'true');
          const iconWrapper = newTab.querySelector('.w-10.h-10');
          if (iconWrapper) {
            iconWrapper.classList.remove('bg-slate-100', 'dark:bg-slate-800', 'text-slate-500', 'dark:text-slate-400');
            iconWrapper.classList.add('bg-primary-100', 'dark:bg-primary-900/40', 'text-primary-600', 'dark:text-primary-400');
          }

          const panel = document.getElementById(targetId);
          if (panel) panel.classList.remove('hidden');
        });
      });
    }

    document.addEventListener('astro:page-load', setupTabs);
  </script>

