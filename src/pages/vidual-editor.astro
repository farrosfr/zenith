---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Badge from '../components/Badge.astro';
import { resolvePath } from '../utils/navigation';
---

<BaseLayout
  title="Vidual Editor"
  description="A revolutionary visual drag-and-drop editor for building stunning web pages without code. Export clean code, collaborate in real time, and ship faster."
>
  <!-- ==================== HERO ==================== -->
  <section class="relative pt-32 pb-32 lg:pt-48 lg:pb-40 overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-white dark:bg-[#09090b]">
      <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyNCIgaGVpZ2h0PSIyNCI+CjxyZWN0IHdpZHRoPSIyNCIgaGVpZ2h0PSIyNCIgZmlsbD0ibm9uZSI+PC9yZWN0Pgo8Y2lyY2xlIGN4PSIxIiBjeT0iMSIgcj0iMSIgZmlsbD0icmdiYSgwLDAsMCwwLjA1KSI+PC9jaXJjbGU+Cjwvc3ZnPg==')] dark:bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyNCIgaGVpZ2h0PSIyNCI+CjxyZWN0IHdpZHRoPSIyNCIgaGVpZ2h0PSIyNCIgZmlsbD0ibm9uZSI+PC9yZWN0Pgo8Y2lyY2xlIGN4PSIxIiBjeT0iMSIgcj0iMSIgZmlsbD0icmdiYSgyNTUsMjU1LDI1NSwwLjA1KSI+PC9jaXJjbGU+Cjwvc3ZnPg==')] [mask-image:linear-gradient(to_bottom,white,transparent)]"></div>
      <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-[800px] h-[600px] bg-primary-400/20 dark:bg-primary-900/30 rounded-full blur-[120px] opacity-80 mix-blend-multiply dark:mix-blend-screen animate-pulse"></div>
      <div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/3 w-[600px] h-[500px] bg-accent-400/20 dark:bg-accent-900/30 rounded-full blur-[100px] opacity-80 mix-blend-multiply dark:mix-blend-screen"></div>
    </div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center reveal-on-scroll">
      <div class="flex justify-center mb-8">
        <Badge variant="primary" class="px-4 py-1.5 text-sm border border-primary-200 dark:border-primary-800 backdrop-blur-md bg-white/50 dark:bg-primary-900/50">
          <span class="mr-2">&#x2728;</span> Vidual Editor — Now available
        </Badge>
      </div>

      <h1 class="text-6xl sm:text-7xl lg:text-8xl font-heading font-extrabold tracking-tight text-slate-900 dark:text-white mb-8 max-w-5xl mx-auto leading-[1.1]">
        Build visually. Ship faster. <span class="text-gradient">No code required.</span>
      </h1>

      <p class="text-xl sm:text-2xl text-slate-600 dark:text-slate-400 mb-12 max-w-3xl mx-auto font-sans leading-relaxed">
        Vidual Editor is a revolutionary drag-and-drop visual builder that lets you create stunning pages,
        export clean production-ready code, and never fight with CSS again.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-20">
        <Button href="#" variant="primary" size="lg" class="w-full sm:w-auto text-lg px-8 py-4 shadow-xl shadow-primary-500/20">
          Buy Now — $50
        </Button>
        <Button href="#features" variant="outline" size="lg" class="w-full sm:w-auto text-lg px-8 py-4 bg-white/50 dark:bg-slate-900/50 backdrop-blur-sm">
          Explore Features
        </Button>
      </div>

      <!-- Editor Mockup -->
      <div class="relative mx-auto max-w-6xl reveal-on-scroll" style="transition-delay: 200ms;">
        <div class="aspect-[16/10] rounded-3xl bg-slate-900 dark:bg-[#111116] shadow-2xl border border-slate-800 dark:border-slate-800/80 overflow-hidden relative group hover-glow">
          <div class="absolute top-4 left-4 flex gap-2 z-20">
            <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
          </div>

          <div class="flex h-full pt-12">
            <!-- Left Layers Panel -->
            <div class="w-64 bg-slate-800/50 dark:bg-slate-900/50 border-r border-slate-700/50 p-4 hidden lg:block">
              <div class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-4">Layers</div>
              <div class="space-y-1">
                <div class="flex items-center gap-2 px-3 py-2 bg-primary-500/20 rounded-lg border border-primary-500/30">
                  <div class="w-4 h-4 rounded bg-primary-500/40"></div>
                  <span class="text-sm text-slate-200">Hero Section</span>
                </div>
                <div class="flex items-center gap-2 px-3 py-2 hover:bg-slate-700/50 rounded-lg transition-colors cursor-pointer">
                  <div class="w-4 h-4 rounded bg-accent-500/40"></div>
                  <span class="text-sm text-slate-400">Features Grid</span>
                </div>
                <div class="flex items-center gap-2 px-3 py-2 hover:bg-slate-700/50 rounded-lg transition-colors cursor-pointer">
                  <div class="w-4 h-4 rounded bg-purple-500/40"></div>
                  <span class="text-sm text-slate-400">Testimonial Card</span>
                </div>
                <div class="flex items-center gap-2 px-3 py-2 hover:bg-slate-700/50 rounded-lg transition-colors cursor-pointer">
                  <div class="w-4 h-4 rounded bg-amber-500/40"></div>
                  <span class="text-sm text-slate-400">Footer</span>
                </div>
              </div>

              <div class="mt-8">
                <div class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-4">Components</div>
                <div class="grid grid-cols-2 gap-2">
                  <div class="px-3 py-2 bg-slate-800 rounded-lg text-center text-xs text-slate-400 hover:bg-slate-700 transition-colors cursor-pointer">Button</div>
                  <div class="px-3 py-2 bg-slate-800 rounded-lg text-center text-xs text-slate-400 hover:bg-slate-700 transition-colors cursor-pointer">Card</div>
                  <div class="px-3 py-2 bg-slate-800 rounded-lg text-center text-xs text-slate-400 hover:bg-slate-700 transition-colors cursor-pointer">Image</div>
                  <div class="px-3 py-2 bg-slate-800 rounded-lg text-center text-xs text-slate-400 hover:bg-slate-700 transition-colors cursor-pointer">Text</div>
                </div>
              </div>
            </div>

            <!-- Canvas -->
            <div class="flex-1 bg-white dark:bg-slate-900 p-6 overflow-hidden flex items-center justify-center">
              <div class="w-full h-full rounded-xl border-2 border-dashed border-slate-200 dark:border-slate-700 flex items-center justify-center">
                <div class="text-center">
                  <div class="w-16 h-16 mx-auto mb-4 bg-primary-100 dark:bg-primary-900/40 rounded-2xl flex items-center justify-center" set:html={`<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary-600 dark:text-primary-400"><path d="M12 5v14"></path><path d="M5 12h14"></path></svg>`} />
                  <p class="text-slate-400 dark:text-slate-500 text-sm font-medium">Drop components here</p>
                  <p class="text-slate-400 dark:text-slate-500 text-xs mt-1">Drag from the sidebar to start building</p>
                </div>
              </div>
            </div>

            <!-- Right Properties Panel -->
            <div class="w-72 bg-slate-800/50 dark:bg-slate-900/50 border-l border-slate-700/50 p-4 hidden lg:block">
              <div class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-4">Properties</div>
              <div class="space-y-4">
                <div>
                  <label class="text-xs text-slate-500 block mb-1">Width</label>
                  <div class="h-8 bg-slate-900/50 rounded-lg border border-slate-700/50 px-3 flex items-center text-sm text-slate-300">100%</div>
                </div>
                <div>
                  <label class="text-xs text-slate-500 block mb-1">Height</label>
                  <div class="h-8 bg-slate-900/50 rounded-lg border border-slate-700/50 px-3 flex items-center text-sm text-slate-300">auto</div>
                </div>
                <div>
                  <label class="text-xs text-slate-500 block mb-1">Background</label>
                  <div class="flex gap-2 items-center">
                    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-primary-400 to-accent-400 border border-slate-700/50 shrink-0"></div>
                    <div class="flex-1 h-8 bg-slate-900/50 rounded-lg border border-slate-700/50 px-3 flex items-center text-sm text-slate-300">#6366f1</div>
                  </div>
                </div>
                <div>
                  <label class="text-xs text-slate-500 block mb-1">Border Radius</label>
                  <div class="h-8 bg-slate-900/50 rounded-lg border border-slate-700/50 px-3 flex items-center">
                    <div class="w-full h-1.5 bg-slate-700 rounded-full relative">
                      <div class="absolute left-0 top-0 h-1.5 w-2/3 bg-primary-500 rounded-full"></div>
                      <div class="absolute top-1/2 -translate-y-1/2 left-2/3 -translate-x-1/2 w-4 h-4 bg-white rounded-full shadow-md border border-slate-600"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="absolute -top-12 -left-12 -z-10 w-96 h-96 bg-primary-500/30 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-[100px]"></div>
        <div class="absolute -bottom-12 -right-12 -z-10 w-96 h-96 bg-accent-500/30 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-[100px]"></div>
      </div>
    </div>
  </section>

  <!-- ==================== DEEP DIVE TABS ==================== -->
  <section id="deep-dive" class="py-32 bg-white dark:bg-[#09090b] relative overflow-hidden">
    <div class="absolute left-0 top-1/3 -translate-x-1/4 w-[500px] h-[500px] bg-accent-500/10 dark:bg-accent-500/5 rounded-full blur-[100px] mix-blend-multiply dark:mix-blend-screen pointer-events-none"></div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-16 reveal-on-scroll">
        <h2 class="text-4xl md:text-5xl font-heading font-extrabold text-slate-900 dark:text-white mb-6">
          See it in action
        </h2>
        <p class="text-xl text-slate-600 dark:text-slate-400">
          Explore each feature of Vidual Editor with a live preview.
        </p>
      </div>

      <div class="max-w-6xl mx-auto lg:grid lg:grid-cols-12 lg:gap-10 items-start">
        <!-- Left: Tab Buttons -->
        <div class="lg:col-span-4 flex lg:flex-col gap-2 mb-8 lg:mb-0 overflow-x-auto lg:overflow-x-visible pb-2 lg:pb-0" role="tablist">
          <button data-tab="tab-drag" class="tab-btn flex items-center gap-3 w-full text-left px-5 py-4 rounded-xl text-sm font-medium transition-all duration-200 bg-primary-50 dark:bg-primary-900/20 text-primary-700 dark:text-primary-300 border border-primary-200 dark:border-primary-800 shadow-sm" role="tab" aria-selected="true">
            <span class="w-10 h-10 rounded-xl bg-primary-100 dark:bg-primary-900/40 text-primary-600 dark:text-primary-400 flex items-center justify-center shrink-0" set:html={`<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 15h14M5 9h14"></path><path d="M12 3v18"></path></svg>`} />
            <div>
              <div class="font-bold text-slate-900 dark:text-white">Drag &amp; Drop Canvas</div>
              <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 hidden lg:block">Pixel-perfect freedom</div>
            </div>
          </button>
          <button data-tab="tab-components" class="tab-btn flex items-center gap-3 w-full text-left px-5 py-4 rounded-xl text-sm font-medium transition-all duration-200 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 border border-transparent" role="tab" aria-selected="false">
            <span class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 flex items-center justify-center shrink-0" set:html={`<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>`} />
            <div>
              <div class="font-bold text-slate-900 dark:text-white">Component Library</div>
              <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 hidden lg:block">200+ ready blocks</div>
            </div>
          </button>
          <button data-tab="tab-collab" class="tab-btn flex items-center gap-3 w-full text-left px-5 py-4 rounded-xl text-sm font-medium transition-all duration-200 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 border border-transparent" role="tab" aria-selected="false">
            <span class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 flex items-center justify-center shrink-0" set:html={`<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>`} />
            <div>
              <div class="font-bold text-slate-900 dark:text-white">Real-time Collaboration</div>
              <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 hidden lg:block">Edit together</div>
            </div>
          </button>
          <button data-tab="tab-ai" class="tab-btn flex items-center gap-3 w-full text-left px-5 py-4 rounded-xl text-sm font-medium transition-all duration-200 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 border border-transparent" role="tab" aria-selected="false">
            <span class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 flex items-center justify-center shrink-0" set:html={`<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg>`} />
            <div>
              <div class="font-bold text-slate-900 dark:text-white">AI Assistant</div>
              <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 hidden lg:block">Generate with AI</div>
            </div>
          </button>
          <button data-tab="tab-export" class="tab-btn flex items-center gap-3 w-full text-left px-5 py-4 rounded-xl text-sm font-medium transition-all duration-200 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 border border-transparent" role="tab" aria-selected="false">
            <span class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 flex items-center justify-center shrink-0" set:html={`<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>`} />
            <div>
              <div class="font-bold text-slate-900 dark:text-white">Export &amp; Code</div>
              <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 hidden lg:block">Clean output</div>
            </div>
          </button>
        </div>

        <!-- Right: Tab Panels -->
        <div class="lg:col-span-8">
          <!-- Tab 1: Drag & Drop -->
          <div id="tab-drag" data-tab-panel class="tab-panel">
            <div class="glass-panel rounded-3xl p-6 sm:p-8 reveal-on-scroll">
              <!-- Screenshot Mockup -->
              <div class="rounded-2xl bg-slate-900 dark:bg-[#111116] border border-slate-700/80 overflow-hidden mb-8 shadow-xl">
                <div class="flex items-center gap-1.5 px-4 pt-3.5 pb-2 bg-slate-800/50 border-b border-slate-700/50">
                  <div class="w-2.5 h-2.5 rounded-full bg-red-500/70"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/70"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-green-500/70"></div>
                  <span class="ml-3 text-xs text-slate-500">canvas.html</span>
                </div>
                <div class="p-6 relative min-h-[260px] flex items-center justify-center bg-[radial-gradient(ellipse_at_center,_#1e293b_0%,_#0f172a_100%)]">
                  <!-- Grid background -->
                  <div class="absolute inset-0 bg-[linear-gradient(to_right,#334155_1px,transparent_1px),linear-gradient(to_bottom,#334155_1px,transparent_1px)] bg-[size:32px_32px] opacity-40"></div>
                  <!-- Draggable elements -->
                  <div class="relative z-10 flex flex-wrap gap-4 justify-center">
                    <div class="w-28 h-20 bg-primary-500/30 rounded-xl border-2 border-primary-400/50 flex items-center justify-center text-xs text-primary-300 cursor-grab active:cursor-grabbing shadow-lg shadow-primary-500/20 select-none relative">
                      Hero
                      <div class="absolute -top-2 -right-2 w-4 h-4 bg-primary-400 rounded-full border-2 border-slate-900"></div>
                    </div>
                    <div class="w-32 h-24 bg-accent-500/30 rounded-xl border-2 border-accent-400/50 flex items-center justify-center text-xs text-accent-300 cursor-grab active:cursor-grabbing shadow-lg shadow-accent-500/20 select-none relative">
                      Features
                      <div class="absolute -top-2 -right-2 w-4 h-4 bg-accent-400 rounded-full border-2 border-slate-900"></div>
                    </div>
                    <div class="w-24 h-16 bg-purple-500/30 rounded-xl border-2 border-dashed border-purple-400/50 flex items-center justify-center text-xs text-purple-300 cursor-grab active:cursor-grabbing shadow-lg select-none relative opacity-70">
                      Footer
                      <div class="absolute -top-2 -right-2 w-4 h-4 bg-purple-400 rounded-full border-2 border-slate-900"></div>
                    </div>
                  </div>
                  <!-- Alignment guide lines -->
                  <div class="absolute left-1/2 top-0 bottom-0 w-px bg-primary-400/40 z-20 hidden md:block"></div>
                  <div class="absolute top-1/2 left-0 right-0 h-px bg-primary-400/40 z-20 hidden md:block"></div>
                  <!-- Smart snap indicator -->
                  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 z-20 bg-slate-900/80 text-xs text-slate-300 px-3 py-1.5 rounded-full border border-slate-700/50 backdrop-blur-sm hidden md:block">
                    <span class="text-primary-400 font-semibold">Snap</span> — aligned to center
                  </div>
                </div>
              </div>

              <h3 class="text-2xl font-heading font-bold text-slate-900 dark:text-white mb-3">Pixel-perfect drag &amp; drop</h3>
              <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-6">
                Unlike other builders that constrain you to rigid grids, Vidual Editor gives you complete freedom.
                Drag any element anywhere with real-time snapping, smart alignment guides, and responsive handles.
                Every movement is smooth, precise, and instantly previewed.
              </p>
              <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-300">
                <li class="flex gap-2.5 items-center">
                  <svg class="h-4 w-4 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                  Smart alignment guides and snapping
                </li>
                <li class="flex gap-2.5 items-center">
                  <svg class="h-4 w-4 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                  Responsive resize handles on every element
                </li>
                <li class="flex gap-2.5 items-center">
                  <svg class="h-4 w-4 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                  Undo/redo with history timeline
                </li>
              </ul>
            </div>
          </div>

          <!-- Tab 2: Component Library -->
          <div id="tab-components" data-tab-panel class="tab-panel hidden">
            <div class="glass-panel rounded-3xl p-6 sm:p-8 reveal-on-scroll">
              <div class="rounded-2xl bg-slate-900 dark:bg-[#111116] border border-slate-700/80 overflow-hidden mb-8 shadow-xl">
                <div class="flex items-center gap-1.5 px-4 pt-3.5 pb-2 bg-slate-800/50 border-b border-slate-700/50">
                  <div class="w-2.5 h-2.5 rounded-full bg-red-500/70"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/70"></div>
                  <div class="w-2.5 h-2.5 rounded-full bg-green-500/70"></div>
                  <span class="ml-3 text-xs text-slate-500">Components — 212 available</span>
                </div>
                <div class="p-5">
                  <div class="grid grid-cols-3 sm:grid-cols-4 gap-3">
                    <div class="aspect-[4/3] bg-slate-800 rounded-xl border border-slate-700/50 p-3 flex flex-col items-center justify-center gap-1.5 hover:border-primary-500/50 hover:bg-slate-800/80 transition-colors cursor-pointer group">
                      <div class="w-8 h-8 rounded-lg bg-primary-500/20 flex items-center justify-center text-primary-400 group-hover:scale-110 transition-transform" set:html={`<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>`} />
                      <span class="text-[11px] text-slate-400 font-medium">Card</span>
                    </div>
                    <div class="aspect-[4/3] bg-slate-800 rounded-xl border border-slate-700/50 p-3 flex flex-col items-center justify-center gap-1.5 hover:border-primary-500/50 hover:bg-slate-800/80 transition-colors cursor-pointer group">
                      <div class="w-8 h-8 rounded-lg bg-accent-500/20 flex items-center justify-center text-accent-400 group-hover:scale-110 transition-transform" set:html={`<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>`} />
                      <span class="text-[11px] text-slate-400 font-medium">Form</span>
                    </div>
